<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {%- set canonicalUrl = site.url + (page.url or "/") %}
  {%- set isArticle = page.url and (page.url | replace('\\', '/')).slice(0, 3) == '/20' %}
  {%- set isHome = page.url == "/" %}
  {%- set realCats = categories | default([]) | realCategories %}
  {%- set primarySection = realCats[0] %}
  {%- set socialImage = (featured_image and (site.url + featured_image)) or (site.social.defaultImage and (site.url + site.social.defaultImage)) %}
  {%- set socialImageAlt = featured_caption or site.social.defaultImageAlt or (title or site.name) %}
  {%- set socialImageWidth = featured_image_width or site.social.defaultImageWidth %}
  {%- set socialImageHeight = featured_image_height or site.social.defaultImageHeight %}
  <title>{% if title %}{{ title }} – {% endif %}{{ site.name }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="canonical" href="{{ canonicalUrl }}">
  {%- if noindex %}
  <meta name="robots" content="noindex,follow">
  {%- endif %}
  <meta property="og:title" content="{{ title or site.name }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:locale" content="{{ site.locale or 'en_US' }}">
  <meta property="og:url" content="{{ canonicalUrl }}">
  <meta property="og:type" content="{% if isArticle %}article{% else %}website{% endif %}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or site.name }}">
  <meta name="twitter:description" content="{{ description or site.description }}">
  {%- if site.social.xSite %}
  <meta name="twitter:site" content="{{ site.social.xSite }}">
  {%- endif %}
  {%- if site.social.xCreator %}
  <meta name="twitter:creator" content="{{ site.social.xCreator }}">
  {%- endif %}
  {%- if socialImage %}
  <meta property="og:image" content="{{ socialImage }}">
  <meta property="og:image:alt" content="{{ socialImageAlt }}">
  <meta property="og:image:width" content="{{ socialImageWidth }}">
  <meta property="og:image:height" content="{{ socialImageHeight }}">
  <meta property="og:image:type" content="image/jpeg">
  <meta name="twitter:image" content="{{ socialImage }}">
  <meta name="twitter:image:alt" content="{{ socialImageAlt }}">
  {%- endif %}
  {%- if isArticle %}
  <meta property="article:published_time" content="{{ page.date | isoDate }}">
  <meta property="article:modified_time" content="{{ page.date | isoDate }}">
  {%- if primarySection %}
  <meta property="article:section" content="{{ primarySection }}">
  {%- endif %}
  {%- if post_tags %}
  {%- for tag in post_tags %}
  <meta property="article:tag" content="{{ tag }}">
  {%- endfor %}
  {%- endif %}
  {%- endif %}
  {%- if site.verification.google %}
  <meta name="google-site-verification" content="{{ site.verification.google }}">
  {%- endif %}
  {%- if site.verification.bing %}
  <meta name="msvalidate.01" content="{{ site.verification.bing }}">
  {%- endif %}
  {#- Fonts: preload only faces used above the fold on this page.
      Brand thin is always in the header; body serif only when reading long text. -#}
  <link rel="preload" href="/assets/fonts/montserrat-100.woff2" as="font" type="font/woff2" crossorigin>
  {%- if isArticle or isHome or featured_image %}
  <link rel="preload" href="/assets/fonts/cormorant-garamond-500.woff2" as="font" type="font/woff2" crossorigin>
  {%- endif %}
  {%- set lcpImage = featured_image %}
  {%- if not lcpImage and isHome and collections.posts and collections.posts.length %}
  {%- set lcpImage = collections.posts[0].data.featured_image %}
  {%- endif %}
  {%- if lcpImage %}
  {%- set lcpWebp = lcpImage | imageWebp %}
  {%- set lcpWebpSrcset = lcpImage | imageWebpSrcset %}
  {%- set lcpSrcset = lcpImage | imageSrcset %}
  {%- if lcpWebp %}
  <link rel="preload" href="{{ lcpWebp }}" as="image" type="image/webp" fetchpriority="high" imagesizes="100vw"{% if lcpWebpSrcset %} imagesrcset="{{ lcpWebpSrcset }}"{% endif %}>
  {%- else %}
  <link rel="preload" href="{{ lcpImage }}" as="image" fetchpriority="high" imagesizes="100vw"{% if lcpSrcset %} imagesrcset="{{ lcpSrcset }}"{% endif %}>
  {%- endif %}
  {%- endif %}
  <link rel="stylesheet" href="{{ cssHref }}">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ site.name | json | safe }},
    "url": {{ site.url | json | safe }},
    "description": {{ site.description | json | safe }},
    "potentialAction": {
      "@type": "SearchAction",
      "target": {{ (site.url + '/search/?q={search_term_string}') | json | safe }},
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": {{ site.author | json | safe }},
    "url": {{ site.url | json | safe }}{% if site.profiles and site.profiles.sameAs and site.profiles.sameAs.length %},
    "sameAs": {{ site.profiles.sameAs | json | safe }}{% endif %}
  }
  </script>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-header" role="banner">
    <a class="site-brand" href="/">
      <span class="site-title">{{ site.name }}</span>
      <span class="site-description">{{ site.tagline }}</span>
    </a>
    <nav class="top-navigation" aria-label="Site">
      <a href="/archive/" {% if page.url == "/archive/" %}aria-current="page"{% endif %}>Musings</a>
      {%- for p in collections.pages %}
      <a href="{{ p.url }}" {% if page.url == p.url %}aria-current="page"{% endif %}>{{ p.data.title }}</a>
      {%- endfor %}
      <a href="/search/" {% if page.url == "/search/" %}aria-current="page"{% endif %}>Search</a>
    </nav>
  </header>
  <main id="main" {% if page.url != "/" %}class="single"{% endif %}>
    {{ content | safe }}
  </main>
  <footer class="site-footer">
    <nav class="bottom-navigation" aria-label="Footer">
      <a href="/">Home</a>
      <a href="/archive/">Musings</a>
      {%- for p in collections.pages %}
      <a href="{{ p.url }}">{{ p.data.title }}</a>
      {%- endfor %}
      <a href="/search/">Search</a>
    </nav>
    <small>© {{ buildYear }} {{ site.name }}. All Rights Reserved. {{ site.footerNote }}</small>
  </footer>
  {%- if site.wpcom.blogId %}
  {#- WordPress.com stats: kept, but deferred until the page is fully loaded
      (and idle when available) so it never competes with LCP. -#}
  <script>
    (function () {
      if (/^(localhost|127\.|0\.0\.0\.0)/.test(location.hostname)) return;
      function loadStats() {
        if (window.__wpStatsLoaded) return;
        window.__wpStatsLoaded = true;
        var s = document.createElement("script");
        s.src = "https://stats.wp.com/e-{{ statsWeek }}.js";
        s.defer = true;
        s.async = true;
        document.body.appendChild(s);
        window._stq = window._stq || [];
        _stq.push(["view", {
          v: "ext",
          blog: "{{ site.wpcom.blogId }}",
          post: "{{ wp_id or 0 }}",
          srv: "{{ site.wpcom.site }}"
        }]);
        _stq.push(["clickTrackerInit", "{{ site.wpcom.blogId }}", "{{ wp_id or 0 }}"]);
      }
      function schedule() {
        if ("requestIdleCallback" in window) {
          requestIdleCallback(loadStats, { timeout: 4000 });
        } else {
          setTimeout(loadStats, 2000);
        }
      }
      if (document.readyState === "complete") schedule();
      else window.addEventListener("load", schedule, { once: true });
    })();
  </script>
  {%- endif %}
</body>
</html>
