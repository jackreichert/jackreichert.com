---
layout: base.njk
pagination:
  data: collections.categories
  size: 1
  alias: category
permalink: "/category/{{ category.slug }}/"
eleventyComputed:
  title: "{{ category.name }}"
  description: "Musings in the {{ category.name }} category, newest first."
---
<section class="archive-wrap">
  <header class="archive-head">
    <h1>{{ category.name }}</h1>
    <p>{{ category.posts | length }} musing{% if category.posts.length != 1 %}s{% endif %}, newest first</p>
  </header>
  <div class="archive-items">
    {%- for post in category.posts %}
    <p class="archive-item">
      <time datetime="{{ post.date | isoDate }}">{{ post.date | isoDate }}</time>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
    </p>
    {%- endfor %}
  </div>
</section>
<nav class="doublebar" aria-label="Musings">
  <small class="db-content">Everything, in one place — <a href="/archive/">musings</a></small>
</nav>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": {{ site.url | json | safe }}
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Musings",
      "item": {{ (site.url + '/archive/') | json | safe }}
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ category.name | json | safe }},
      "item": {{ (site.url + '/category/' + category.slug + '/') | json | safe }}
    }
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ (category.name + ' Musings') | json | safe }},
  "itemListOrder": "https://schema.org/ItemListOrderDescending",
  "numberOfItems": {{ category.posts | length }},
  "itemListElement": [
    {%- for post in category.posts %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "url": {{ (site.url + post.url) | json | safe }},
      "name": {{ post.data.title | json | safe }}
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>
